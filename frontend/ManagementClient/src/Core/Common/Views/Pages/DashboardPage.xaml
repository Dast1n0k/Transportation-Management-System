<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="ManagementClient.Core.Common.Views.Bridges.DashboardPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ManagementClient.Core.Common.Converters"
             x:Name="DashboardPageRoot"
             Title="{Binding Title}"
             Style="{StaticResource BasePageStyle}">

    <ContentPage.Resources>
        <converters:ViewToggleStyleConverter x:Key="ViewToggleStyleConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              Padding="20,10"
              BackgroundColor="{DynamicResource SurfaceBackgroundColor}">

            <Label Grid.Column="0"
                   Text="Logistics Dashboard"
                   Style="{StaticResource SectionTitleLabelStyle}"
                   VerticalOptions="Center"/>

            <Button Grid.Column="1"
                    Text="Logout"
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1"
              ColumnDefinitions="280,*">

            <!-- Sidebar with right border -->
            <Grid Grid.Column="0" BackgroundColor="{DynamicResource SurfaceBackgroundColor}">

                <ScrollView Padding="20">
                    <StackLayout Spacing="20">

                        <!-- Search Section -->
                        <StackLayout Spacing="12">
                            <Label Text="Search Deliveries"
                                   Style="{StaticResource SubtitleLabelStyle}"/>

                            <Label Text="Zip Code"
                                   Style="{StaticResource BodyLabelStyle}"/>
                            <Entry Placeholder="Enter zip code"
                                   Text="{Binding ZipCode}"
                                   Style="{StaticResource RoundedEntryStyle}"
                                   FontSize="18"
                                   HeightRequest="50"/>

                            <Label Text="Radius (miles)"
                                   Style="{StaticResource BodyLabelStyle}"/>
                            <Picker ItemsSource="{Binding RadiusOptions}"
                                    SelectedItem="{Binding RadiusInMiles}"
                                    Style="{StaticResource RoundedEntryStyle}"
                                    Title="Select radius"
                                    FontSize="18"
                                    HeightRequest="75"
                                    HorizontalTextAlignment="Center"
                                    BackgroundColor="{DynamicResource SurfaceBackgroundColor}"/>

                            <Button Text="🔍 Search Couriers"
                                    Command="{Binding SearchZipcodeCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    FontSize="16"
                                    HeightRequest="50"
                                    Margin="0,10,0,0"/>
                        </StackLayout>

                        <!-- Search Results - ONLY VISIBLE AFTER SEARCH -->
                        <StackLayout Spacing="12" 
                                     IsVisible="{Binding HasPerformedSearch}">
                            <Label Text="Available Couriers"
                                   Style="{StaticResource SubtitleLabelStyle}"/>

                            <CollectionView ItemsSource="{Binding FilteredDeliveryPersons}"
                                            Style="{StaticResource BaseCollectionViewStyle}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardBorderStyle}"
                                                Margin="0,4">
                                            <Grid Padding="12"
                                                  ColumnDefinitions="Auto,*,Auto,Auto"
                                                  RowDefinitions="Auto,Auto,Auto"
                                                  RowSpacing="6">

                                                <!-- Vehicle Icon -->
                                                <Label Grid.Column="0" Grid.RowSpan="3"
                                                       Text="{Binding VehicleIcon}"
                                                       FontSize="28"
                                                       VerticalOptions="Center"
                                                       Margin="0,0,12,0"/>

                                                <!-- Name and Location -->
                                                <StackLayout Grid.Column="1" Grid.Row="0" 
                                                           VerticalOptions="Center">
                                                    <Label Text="{Binding Name}"
                                                           Style="{StaticResource BodyLabelStyle}"
                                                           FontAttributes="Bold"
                                                           FontSize="16"
                                                           Margin="0"/>
                                                    <Label Text="{Binding Location, StringFormat='📍 {0}'}"
                                                           Style="{StaticResource CaptionLabelStyle}"
                                                           FontSize="13"
                                                           Margin="0,2,0,0"/>
                                                </StackLayout>

                                                <!-- Capacity Info (removed vehicle type) -->
                                                <StackLayout Grid.Column="1" Grid.Row="1" 
                                                           Orientation="Horizontal"
                                                           Spacing="12"
                                                           Margin="0,4,0,0">
                                                    <Label Text="{Binding Capacity, StringFormat='📦 {0}'}"
                                                           Style="{StaticResource CaptionLabelStyle}"
                                                           FontSize="12"/>
                                                </StackLayout>

                                                <!-- Dimensions and Phone -->
                                                <StackLayout Grid.Column="1" Grid.Row="2" 
                                                           Orientation="Horizontal"
                                                           Spacing="12"
                                                           Margin="0,2,0,0">
                                                    <Label Text="{Binding Dimensions, StringFormat='📏 {0}'}"
                                                           Style="{StaticResource CaptionLabelStyle}"
                                                           FontSize="12"/>
                                                    <Label Text="{Binding Phone, StringFormat='📞 {0}'}"
                                                           Style="{StaticResource CaptionLabelStyle}"
                                                           FontSize="12"/>
                                                </StackLayout>

                                                <!-- Copy Button -->
                                                <Button Grid.Column="3" Grid.Row="0" Grid.RowSpan="3"
                                                        Text="📋"
                                                        Command="{Binding BindingContext.CopyCourierDataCommand, Source={x:Reference Name=DashboardPageRoot}}"
                                                        CommandParameter="{Binding .}"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        FontSize="14"
                                                        WidthRequest="40"
                                                        HeightRequest="40"
                                                        Padding="0"
                                                        VerticalOptions="Center"/>

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </StackLayout>

                        <!-- Remove the "Enter zipcode" message completely -->

                    </StackLayout>
                </ScrollView>

                <!-- Right border using BoxView -->
                <BoxView BackgroundColor="{DynamicResource DividerColor}"
                         WidthRequest="1"
                         HorizontalOptions="End"
                         VerticalOptions="FillAndExpand"/>
            </Grid>

            <!-- Main Content Area -->
            <Grid Grid.Column="1">

                <!-- Tab Header -->
                <Grid RowDefinitions="Auto,*">

                    <!-- View Toggle with bottom border -->
                    <Grid Grid.Row="0"
                          BackgroundColor="{DynamicResource SurfaceBackgroundColor}"
                          Padding="20,10">

                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">

                            <!-- View Toggle Buttons -->
                            <Button Grid.Column="0"
                                    Text="Map View"
                                    Command="{Binding SwitchToMapViewCommand}"
                                    Style="{Binding IsMapView, Converter={StaticResource ViewToggleStyleConverter}}"/>

                            <Button Grid.Column="1"
                                    Text="Delivery Guys"
                                    Command="{Binding SwitchToListViewCommand}"
                                    Style="{Binding IsListView, Converter={StaticResource ViewToggleStyleConverter}}"
                                    Margin="8,0,0,0"/>

                            <!-- Add New Button -->
                            <Button Grid.Column="3"
                                    Text="+ Add New"
                                    Command="{Binding AddNewDeliveryPersonCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    FontSize="14"
                                    HeightRequest="36"
                                    Padding="16,0"/>
                        </Grid>

                        <!-- Bottom border using BoxView -->
                        <BoxView BackgroundColor="{DynamicResource DividerColor}"
                                 HeightRequest="1"
                                 VerticalOptions="End"
                                 HorizontalOptions="FillAndExpand"/>
                    </Grid>

                    <!-- Content Area -->
                    <Grid Grid.Row="1">

                        <!-- Map View with WebView -->
                        <Grid IsVisible="{Binding IsMapView}">
                            <WebView x:Name="CourierMapWebView"
                                     VerticalOptions="FillAndExpand"
                                     HorizontalOptions="FillAndExpand"
                                     BackgroundColor="White"/>
                        </Grid>

                        <!-- List View -->
                        <ScrollView IsVisible="{Binding IsListView}">
                            <StackLayout Padding="20"
                                         Spacing="20">

                                <!-- Header -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="Delivery Personnel Management"
                                           Style="{StaticResource SectionTitleLabelStyle}"/>
                                </Grid>

                                <!-- Delivery Personnel Cards -->
                                <CollectionView ItemsSource="{Binding FilteredDeliveryPersons}"
                                                Style="{StaticResource BaseCollectionViewStyle}">
                                    <CollectionView.ItemsLayout>
                                        <GridItemsLayout Orientation="Vertical"
                                                         Span="3"/>
                                    </CollectionView.ItemsLayout>

                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorderStyle}">
                                                <StackLayout Spacing="12">

                                                    <!-- Header with Name and Status -->
                                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                                        <Label Grid.Column="0"
                                                               Text="{Binding Name}"
                                                               Style="{StaticResource SubtitleLabelStyle}"
                                                               FontAttributes="Bold"/>

                                                        <Border Grid.Column="1"
                                                                Style="{StaticResource StatusBadgeStyle}"
                                                                BackgroundColor="{Binding StatusColor}">
                                                            <Label Text="{Binding StatusText}"
                                                                   TextColor="White"
                                                                   FontSize="10"
                                                                   FontAttributes="Bold"
                                                                   HorizontalOptions="Center"/>
                                                        </Border>

                                                        <Label Grid.Column="2"
                                                               Text="{Binding VehicleIcon}"
                                                               FontSize="20"
                                                               VerticalOptions="Center"
                                                               Margin="8,0,0,0"/>
                                                    </Grid>

                                                    <!-- Contact Info -->
                                                    <StackLayout Spacing="4">
                                                        <Label Text="{Binding Phone}"
                                                               Style="{StaticResource CaptionLabelStyle}"/>
                                                        <Label Text="{Binding Location, StringFormat='📍 {0}'}"
                                                               Style="{StaticResource CaptionLabelStyle}"/>
                                                    </StackLayout>

                                                    <!-- Action Buttons -->
                                                    <Grid ColumnDefinitions="*,*"
                                                          ColumnSpacing="8"
                                                          Margin="0,8,0,0">
                                                        <Button Grid.Column="0"
                                                                Text="Edit"
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditDeliveryPersonCommand}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButtonStyle}"
                                                                FontSize="12"/>

                                                        <Button Grid.Column="1"
                                                                Text="Delete"
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteDeliveryPersonCommand}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource DangerButtonStyle}"
                                                                FontSize="12"/>
                                                    </Grid>

                                                </StackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <!-- Loading Indicator -->
                                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                                   IsRunning="{Binding IsBusy}"
                                                   Style="{StaticResource LoadingIndicatorStyle}"
                                                   Margin="0,40"/>

                            </StackLayout>
                        </ScrollView>

                    </Grid>

                </Grid>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>