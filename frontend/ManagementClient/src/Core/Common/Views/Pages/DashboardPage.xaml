<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="ManagementClient.Core.Common.Views.Bridges.DashboardPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}"
             Style="{StaticResource BasePageStyle}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              Padding="20,10"
              BackgroundColor="{DynamicResource SurfaceBackgroundColor}">

            <Label Grid.Column="0"
                   Text="Logistics Dashboard"
                   Style="{StaticResource SectionTitleLabelStyle}"
                   VerticalOptions="Center"/>

            <Button Grid.Column="1"
                    Text="Logout"
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1"
                ColumnDefinitions="280,*">

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    BackgroundColor="{DynamicResource SurfaceBackgroundColor}"
                    Stroke="{DynamicResource DividerColor}"
                    StrokeThickness="0,0,1,0">

                <ScrollView Padding="20">
                    <StackLayout Spacing="20">

                        <!-- Search Section -->
                        <StackLayout Spacing="12">
                            <Label Text="Search Deliveries"
                                    Style="{StaticResource SubtitleLabelStyle}"/>

                            <Label Text="Zip Code"
                                    Style="{StaticResource BodyLabelStyle}"/>
                            <Entry Placeholder="Enter zip code"
                                   Text="{Binding ZipCode}"
                                   Style="{StaticResource RoundedEntryStyle}"/>

                            <Label Text="Radius (miles)"
                                    Style="{StaticResource BodyLabelStyle}"/>
                            <Stepper Value="{Binding RadiusInMiles}"
                                     Minimum="1"
                                    Maximum="50"
                                    Increment="1"/>
                            <Label Text="{Binding RadiusInMiles}"
                                   Style="{StaticResource CaptionLabelStyle}"
                                   HorizontalOptions="Center"/>

                            <Button Text="Search"
                                    Command="{Binding SearchCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                        </StackLayout>

                        <!-- Delivery Personnel List -->
                        <StackLayout Spacing="12">
                            <Label Text="Delivery Personnel"
                                    Style="{StaticResource SubtitleLabelStyle}"/>

                            <CollectionView ItemsSource="{Binding FilteredDeliveryPersons}"
                                            Style="{StaticResource BaseCollectionViewStyle}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,8"
                                                ColumnDefinitions="Auto,*,Auto">

                                            <!-- Vehicle Icon -->
                                            <Label Grid.Column="0"
                                                   Text="{Binding VehicleIcon}"
                                                   FontSize="16"
                                                   VerticalOptions="Center"
                                                   Margin="0,0,8,0"/>

                                            <!-- Person Info -->
                                            <StackLayout Grid.Column="1"
                                                    Spacing="2">
                                                <Label Text="{Binding Name}"
                                                       Style="{StaticResource BodyLabelStyle}"
                                                       FontAttributes="Bold"/>
                                                <Label Text="{Binding Location}"
                                                       Style="{StaticResource CaptionLabelStyle}"/>
                                            </StackLayout>

                                            <!-- Status Indicator -->
                                            <Ellipse Grid.Column="2"
                                                     Fill="{Binding StatusColor}"
                                                     WidthRequest="12"
                                                     HeightRequest="12"
                                                     VerticalOptions="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </StackLayout>

                    </StackLayout>
                </ScrollView>

            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1">

                <!-- Tab Header -->
                <Grid RowDefinitions="Auto,*">

                    <!-- View Toggle -->
                    <Border Grid.Row="0"
                            BackgroundColor="{DynamicResource SurfaceBackgroundColor}"
                            Stroke="{DynamicResource DividerColor}"
                            StrokeThickness="0,0,0,1"
                            Padding="20,10">

                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">

                            <!-- View Toggle Buttons -->
                            <Button Grid.Column="0"
                                    Text="🗺️ Map View"
                                    Command="{Binding SwitchToMapViewCommand}"
                                    Style="{Binding IsMapView, Converter={StaticResource ViewToggleStyleConverter}}"/>

                            <Button Grid.Column="1"
                                    Text="👥 Delivery Guys"
                                    Command="{Binding SwitchToListViewCommand}"
                                    Style="{Binding IsListView, Converter={StaticResource ViewToggleStyleConverter}}"
                                    Margin="8,0,0,0"/>

                            <!-- Add New Button -->
                            <Button Grid.Column="3"
                                    Text="+ Add New"
                                    Command="{Binding AddNewDeliveryPersonCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    FontSize="14"
                                    HeightRequest="36"
                                    Padding="16,0"/>
                        </Grid>
                    </Border>

                    <!-- Content Area -->
                    <Grid Grid.Row="1">

                        <!-- Map View -->
                        <Grid IsVisible="{Binding IsMapView}">
                            <WebView x:Name="MapWebView"
                                     Source="map.html"
                                     VerticalOptions="FillAndExpand"
                                     HorizontalOptions="FillAndExpand"/>

                            <!-- Map Placeholder -->
                            <Border IsVisible="True"
                                    BackgroundColor="{DynamicResource InputBackgroundColor}"
                                    Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="1"
                                    Margin="20">
                                <StackLayout VerticalOptions="Center"
                                        HorizontalOptions="Center"
                                        Spacing="10">
                                    <Label Text="🗺️"
                                            FontSize="48"
                                            HorizontalOptions="Center"/>
                                    <Label Text="Interactive map would be displayed here"
                                           Style="{StaticResource SubtitleLabelStyle}"
                                           HorizontalTextAlignment="Center"/>
                                    <Label Text="Showing delivery personnel and their locations"
                                           Style="{StaticResource CaptionLabelStyle}"
                                           HorizontalTextAlignment="Center"/>
                                </StackLayout>
                            </Border>
                        </Grid>

                        <!-- List View -->
                        <ScrollView IsVisible="{Binding IsListView}">
                            <StackLayout Padding="20"
                                    Spacing="20">

                                <!-- Header -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="Delivery Personnel Management"
                                           Style="{StaticResource SectionTitleLabelStyle}"/>
                                </Grid>

                                <!-- Delivery Personnel Cards -->
                                <CollectionView ItemsSource="{Binding FilteredDeliveryPersons}"
                                                Style="{StaticResource BaseCollectionViewStyle}">
                                    <CollectionView.ItemsLayout>
                                        <GridItemsLayout Orientation="Vertical"
                                                Span="3"/>
                                    </CollectionView.ItemsLayout>

                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorderStyle}">
                                                <StackLayout Spacing="12">

                                                    <!-- Header with Name and Status -->
                                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                                        <Label Grid.Column="0"
                                                               Text="{Binding Name}"
                                                               Style="{StaticResource SubtitleLabelStyle}"
                                                               FontAttributes="Bold"/>

                                                        <Border Grid.Column="1"
                                                                Style="{StaticResource StatusBadgeStyle}"
                                                                BackgroundColor="{Binding StatusColor}">
                                                            <Label Text="{Binding Status}"
                                                                   TextColor="White"
                                                                   FontSize="10"
                                                                   FontAttributes="Bold"
                                                                   HorizontalOptions="Center"/>
                                                        </Border>

                                                        <Label Grid.Column="2"
                                                               Text="{Binding VehicleIcon}"
                                                               FontSize="20"
                                                               VerticalOptions="Center"
                                                               Margin="8,0,0,0"/>
                                                    </Grid>

                                                    <!-- Contact Info -->
                                                    <StackLayout Spacing="4">
                                                        <Label Text="{Binding Email}"
                                                               Style="{StaticResource CaptionLabelStyle}"/>
                                                        <Label Text="{Binding Phone}"
                                                               Style="{StaticResource CaptionLabelStyle}"/>
                                                        <Label Text="{Binding Location, StringFormat='📍 {0}'}"
                                                               Style="{StaticResource CaptionLabelStyle}"/>
                                                    </StackLayout>

                                                    <!-- Action Buttons -->
                                                    <Grid ColumnDefinitions="*,*"
                                                            ColumnSpacing="8"
                                                            Margin="0,8,0,0">
                                                        <Button Grid.Column="0"
                                                                Text="✏️ Edit"
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditDeliveryPersonCommand}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButtonStyle}"
                                                                FontSize="12"/>

                                                        <Button Grid.Column="1"
                                                                Text="🗑️ Delete"
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteDeliveryPersonCommand}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource DangerButtonStyle}"
                                                                FontSize="12"/>
                                                    </Grid>

                                                </StackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <!-- Loading Indicator -->
                                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                                   IsRunning="{Binding IsBusy}"
                                                   Style="{StaticResource LoadingIndicatorStyle}"
                                                   Margin="0,40"/>

                            </StackLayout>
                        </ScrollView>

                    </Grid>

                </Grid>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>