<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="ManagementClient.Core.Common.Views.Bridges.DeliveryPersonModalPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}"
             Style="{StaticResource BasePageStyle}">

    <Grid RowDefinitions="*,Auto">

        <!-- Overlay Background -->
        <BoxView Grid.RowSpan="2"
                 Color="{DynamicResource OverlayBackgroundColor}"/>

        <!-- Modal Content -->
        <ScrollView Grid.Row="0"
                VerticalOptions="Center">
            <Border Style="{StaticResource ModalBorderStyle}"
                    MaximumWidthRequest="500"
                    HorizontalOptions="Center"
                    Margin="20">

                <StackLayout Spacing="24">

                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="{Binding Title}"
                               Style="{StaticResource SectionTitleLabelStyle}"/>

                        <Button Grid.Column="1"
                                Text="✕"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource IconButtonStyle}"
                                FontSize="18"
                                BackgroundColor="Transparent"/>
                    </Grid>

                    <!-- Form Content -->
                    <StackLayout Spacing="16">

                        <!-- Name Field -->
                        <StackLayout Spacing="4">
                            <Label Text="Name"
                                    Style="{StaticResource BodyLabelStyle}"/>
                            <Entry Placeholder="Enter full name"
                                   Text="{Binding Name}"
                                   Style="{StaticResource RoundedEntryStyle}"/>
                        </StackLayout>

                        <!-- Email Field -->
                        <StackLayout Spacing="4">
                            <Label Text="Email"
                                    Style="{StaticResource BodyLabelStyle}"/>
                            <Entry Placeholder="Enter email address"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   Style="{StaticResource RoundedEntryStyle}"/>
                        </StackLayout>

                        <!-- Phone Field -->
                        <StackLayout Spacing="4">
                            <Label Text="Phone"
                                    Style="{StaticResource BodyLabelStyle}"/>
                            <Entry Placeholder="Enter phone number"
                                   Text="{Binding Phone}"
                                   Keyboard="Telephone"
                                   Style="{StaticResource RoundedEntryStyle}"/>
                        </StackLayout>

                        <!-- Vehicle Type Field -->
                        <StackLayout Spacing="4">
                            <Label Text="Vehicle Type"
                                    Style="{StaticResource BodyLabelStyle}"/>
                            <Picker ItemsSource="{Binding VehicleTypes}"
                                    SelectedItem="{Binding SelectedVehicleType}"
                                    Style="{StaticResource BasePicker}"/>
                        </StackLayout>

                        <!-- Status Field -->
                        <StackLayout Spacing="4">
                            <Label Text="Status"
                                    Style="{StaticResource BodyLabelStyle}"/>
                            <Picker ItemsSource="{Binding StatusOptions}"
                                    SelectedItem="{Binding SelectedStatus}"
                                    Style="{StaticResource BasePicker}"/>
                        </StackLayout>

                        <!-- Location Field -->
                        <StackLayout Spacing="4">
                            <Label Text="Location"
                                    Style="{StaticResource BodyLabelStyle}"/>
                            <Entry Placeholder="Enter current location/zone"
                                   Text="{Binding Location}"
                                   Style="{StaticResource RoundedEntryStyle}"/>
                        </StackLayout>

                    </StackLayout>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="12"
                            Margin="0,16,0,0">

                        <Button Grid.Column="0"
                                Text="Cancel"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>

                        <Button Grid.Column="1"
                                Text="{Binding IsEdit, Converter={StaticResource SaveButtonTextConverter}}"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </Grid>

                    <!-- Loading Indicator -->
                    <ActivityIndicator IsVisible="{Binding IsBusy}"
                                       IsRunning="{Binding IsBusy}"
                                       Style="{StaticResource LoadingIndicatorStyle}"/>

                </StackLayout>

            </Border>
        </ScrollView>

    </Grid>

</ContentPage>