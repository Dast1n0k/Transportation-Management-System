<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="ManagementClient.Core.Common.Views.Bridges.LoginPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}"
             Style="{StaticResource BasePageStyle}"
             Shell.NavBarIsVisible="False">

       <ScrollView>
              <Grid RowDefinitions="*,Auto,*"
                            Margin="40">

                     <!-- Logo/Title Section -->
                     <StackLayout Grid.Row="1"
                                   Spacing="40"
                                   VerticalOptions="Center">

                            <!-- Title -->
                            <Label Text="Logistics Operator Login"
                                   Style="{StaticResource TitleLabelStyle}"
                                   Margin="0,0,0,40"/>

                            <!-- Login Form -->
                            <Border Style="{StaticResource CardBorderStyle}"
                                          Padding="32">
                                   <StackLayout Spacing="20">

                                          <!-- Email Field -->
                                          <StackLayout Spacing="8">
                                                 <Entry Placeholder="Email"
                                                        Text="{Binding Email}"
                                                        Keyboard="Email"
                                                        Style="{StaticResource RoundedEntryStyle}"
                                                        ReturnType="Next"/>
                                          </StackLayout>

                                          <!-- Password Field -->
                                          <StackLayout Spacing="8">
                                                 <Grid ColumnDefinitions="*,Auto">
                                                        <Entry Grid.Column="0"
                                                               Placeholder="Password"
                                                               Text="{Binding Password}"
                                                               IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                                                               Style="{StaticResource RoundedEntryStyle}"
                                                               ReturnType="Done"
                                                               ReturnCommand="{Binding LoginCommand}"/>

                                                        <Button Grid.Column="1"
                                                                Text="{Binding IsPasswordVisible, Converter={StaticResource PasswordVisibilityConverter}}"
                                                                Command="{Binding TogglePasswordVisibilityCommand}"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                VerticalOptions="Center"
                                                                Margin="8,0,0,0"/>
                                                 </Grid>
                                          </StackLayout>

                                          <!-- Error Message -->
                                          <Label Text="{Binding ErrorMessage}"
                                                 TextColor="{DynamicResource ErrorColor}"
                                                 Style="{StaticResource CaptionLabelStyle}"
                                                 IsVisible="{Binding HasError}"
                                                 HorizontalTextAlignment="Center"/>

                                          <!-- Login Button -->
                                          <Button Text="Login"
                                                  Command="{Binding LoginCommand}"
                                                  Style="{StaticResource PrimaryButtonStyle}"
                                                  Margin="0,20,0,0"/>

                                          <!-- Loading Indicator -->
                                          <ActivityIndicator IsVisible="{Binding IsBusy}"
                                                             IsRunning="{Binding IsBusy}"
                                                             Style="{StaticResource LoadingIndicatorStyle}"/>

                                   </StackLayout>
                            </Border>

                     </StackLayout>

              </Grid>
       </ScrollView>

</ContentPage>