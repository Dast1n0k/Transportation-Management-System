        <Style x:Key="BasePageStyle"
                        TargetType="ContentPage">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource PageBackgroundColor}"/>
        </Style>

        <Style x:Key="TitleLabelStyle"
                        TargetType="Label">
                <Setter Property="FontSize"
                                Value="30"/>
                <Setter Property="FontAttributes"
                                Value="Bold"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource PrimaryTextColor}"/>
                <Setter Property="HorizontalTextAlignment"
                                Value="Center"/>
        </Style>

        <Style x:Key="SectionTitleLabelStyle"
                        TargetType="Label">
                <Setter Property="FontSize"
                                Value="22"/>
                <Setter Property="FontAttributes"
                                Value="Bold"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource PrimaryTextColor}"/>
        </Style>

        <Style x:Key="SubtitleLabelStyle"
                        TargetType="Label">
                <Setter Property="FontSize"
                                Value="18"/>
                <Setter Property="FontAttributes"
                                Value="Bold"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource PrimaryTextColor}"/>
        </Style>

        <Style x:Key="BodyLabelStyle"
                        TargetType="Label">
                <Setter Property="FontSize"
                                Value="14"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource PrimaryTextColor}"/>
        </Style>

        <Style x:Key="CaptionLabelStyle"
                        TargetType="Label">
                <Setter Property="FontSize"
                                Value="12"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource SecondaryTextColor}"/>
        </Style>

        <Style x:Key="BaseButtonStyle"
                        TargetType="Button">
                <Setter Property="HeightRequest"
                                Value="48"/>
                <Setter Property="FontSize"
                                Value="16"/>
                <Setter Property="FontAttributes"
                                Value="Bold"/>
                <Setter Property="CornerRadius"
                                Value="8"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle"
                        TargetType="Button"
                        BasedOn="{StaticResource BaseButtonStyle}">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource Primary}"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource LightTextColor}"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
                        TargetType="Button"
                        BasedOn="{StaticResource BaseButtonStyle}">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource Secondary}"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource LightTextColor}"/>
        </Style>

        <Style x:Key="DangerButtonStyle"
                        TargetType="Button"
                        BasedOn="{StaticResource BaseButtonStyle}">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource Danger}"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource LightTextColor}"/>
        </Style>

        <Style x:Key="IconButtonStyle"
                        TargetType="Button">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource SurfaceBackgroundColor}"/>
                <Setter Property="BorderColor"
                                Value="{DynamicResource BorderColor}"/>
                <Setter Property="BorderWidth"
                                Value="0"/>
                <Setter Property="WidthRequest"
                                Value="40"/>
                <Setter Property="HeightRequest"
                                Value="40"/>
                <Setter Property="CornerRadius"
                                Value="20"/>
                <Setter Property="FontSize"
                                Value="16"/>
                <Setter Property="Padding"
                                Value="0"/>
        </Style>

        <Style x:Key="ActiveToggleButtonStyle"
                        TargetType="Button"
                        BasedOn="{StaticResource BaseButtonStyle}">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource Primary}"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource LightTextColor}"/>
        </Style>

        <Style x:Key="InactiveToggleButtonStyle"
                        TargetType="Button"
                        BasedOn="{StaticResource BaseButtonStyle}">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource SurfaceBackgroundColor}"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource PrimaryTextColor}"/>
                <Setter Property="BorderColor"
                                Value="{DynamicResource BorderColor}"/>
                <Setter Property="BorderWidth"
                                Value="1"/>
        </Style>

        <Style x:Key="RoundedEntryStyle"
                        TargetType="Entry">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource InputBackgroundColor}"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource PrimaryTextColor}"/>
                <Setter Property="PlaceholderColor"
                                Value="{DynamicResource SecondaryTextColor}"/>
                <Setter Property="HeightRequest"
                                Value="48"/>
                <Setter Property="FontSize"
                                Value="16"/>
        </Style>

        <Style x:Key="RoundedEditorStyle"
                        TargetType="Editor">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource InputBackgroundColor}"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource PrimaryTextColor}"/>
                <Setter Property="PlaceholderColor"
                                Value="{DynamicResource SecondaryTextColor}"/>
                <Setter Property="FontSize"
                                Value="16"/>
        </Style>

        <Style x:Key="BasePicker"
                        TargetType="Picker">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource InputBackgroundColor}"/>
                <Setter Property="TextColor"
                                Value="{DynamicResource PrimaryTextColor}"/>
                <Setter Property="TitleColor"
                                Value="{DynamicResource SecondaryTextColor}"/>
                <Setter Property="HeightRequest"
                                Value="48"/>
                <Setter Property="FontSize"
                                Value="16"/>
        </Style>

        <Style x:Key="CardBorderStyle"
                        TargetType="Border">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource CardBackgroundColor}"/>
                <Setter Property="Stroke"
                                Value="{DynamicResource BorderColor}"/>
                <Setter Property="StrokeThickness"
                                Value="1.5"/>
                <Setter Property="StrokeShape"
                                Value="RoundRectangle 8"/>
                <Setter Property="Padding"
                                Value="12"/>
                <Setter Property="Margin"
                                Value="0,4"/>
        </Style>

        <Style x:Key="ModalBorderStyle"
                        TargetType="Border">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource CardBackgroundColor}"/>
                <Setter Property="Stroke"
                                Value="{DynamicResource BorderColor}"/>
                <Setter Property="StrokeThickness"
                                Value="1.5"/>
                <Setter Property="StrokeShape"
                                Value="RoundRectangle 12"/>
                <Setter Property="Padding"
                                Value="24"/>
        </Style>

        <Style x:Key="StatusBadgeStyle"
                        TargetType="Border">
                <Setter Property="StrokeShape"
                                Value="RoundRectangle 10"/>
                <Setter Property="Padding"
                                Value="8,4"/>
                <Setter Property="HorizontalOptions"
                                Value="Start"/>
        </Style>

        <Style x:Key="BaseCollectionViewStyle"
                        TargetType="CollectionView">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource PageBackgroundColor}"/>
                <Setter Property="SelectionMode"
                                Value="None"/>
        </Style>

        <Style x:Key="LoadingIndicatorStyle"
                        TargetType="ActivityIndicator">
                <Setter Property="Color"
                                Value="{DynamicResource Primary}"/>
                <Setter Property="HeightRequest"
                                Value="40"/>
                <Setter Property="WidthRequest"
                                Value="40"/>
                <Setter Property="HorizontalOptions"
                                Value="Center"/>
                <Setter Property="VerticalOptions"
                                Value="Center"/>
        </Style>

</ResourceDictionary>