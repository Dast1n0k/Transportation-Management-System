<?xml version="1.0" encoding="UTF-8" ?>
<!-- <?xaml-comp compile="true" ?> -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:converters="clr-namespace:ManagementClient.Core.Common.Converters">

        <!-- Value Converters -->
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        <converters:PasswordVisibilityConverter x:Key="PasswordVisibilityConverter"/>
        <converters:SaveButtonTextConverter x:Key="SaveButtonTextConverter"/>
        <converters:ViewToggleStyleConverter x:Key="ViewToggleStyleConverter"/>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <converters:VehicleTypeToIconConverter x:Key="VehicleTypeToIconConverter"/>

        <!-- Base Styles -->
        <Style x:Key="BasePageStyle"
               TargetType="ContentPage">
                <Setter Property="BackgroundColor"
                        Value="{DynamicResource PageBackgroundColor}"/>
        </Style>

        <!-- Label Styles -->
        <Style x:Key="TitleLabelStyle"
               TargetType="Label">
                <Setter Property="FontSize"
                        Value="24"/>
                <Setter Property="FontAttributes"
                        Value="Bold"/>
                <Setter Property="TextColor"
                        Value="{DynamicResource PrimaryTextColor}"/>
                <Setter Property="HorizontalOptions"
                        Value="Center"/>
        </Style>

        <Style x:Key="SectionTitleLabelStyle"
               TargetType="Label">
                <Setter Property="FontSize"
                        Value="20"/>
                <Setter Property="FontAttributes"
                        Value="Bold"/>
                <Setter Property="TextColor"
                        Value="{DynamicResource PrimaryTextColor}"/>
                <Setter Property="Margin"
                        Value="0,10,0,5"/>
        </Style>

        <Style x:Key="SubtitleLabelStyle"
               TargetType="Label">
                <Setter Property="FontSize"
                        Value="16"/>
                <Setter Property="TextColor"
                        Value="{DynamicResource SecondaryTextColor}"/>
        </Style>

        <Style x:Key="BodyLabelStyle"
               TargetType="Label">
                <Setter Property="FontSize"
                        Value="14"/>
                <Setter Property="TextColor"
                        Value="{DynamicResource PrimaryTextColor}"/>
        </Style>

        <Style x:Key="CaptionLabelStyle"
               TargetType="Label">
                <Setter Property="FontSize"
                        Value="12"/>
                <Setter Property="TextColor"
                        Value="{DynamicResource SecondaryTextColor}"/>
        </Style>

        <!-- Entry Styles -->
        <Style x:Key="BaseEntryStyle"
               TargetType="Entry">
                <Setter Property="BackgroundColor"
                        Value="{DynamicResource InputBackgroundColor}"/>
                <Setter Property="TextColor"
                        Value="{DynamicResource PrimaryTextColor}"/>
                <Setter Property="PlaceholderColor"
                        Value="{DynamicResource PlaceholderTextColor}"/>
                <Setter Property="FontSize"
                        Value="14"/>
                <Setter Property="HeightRequest"
                        Value="48"/>
                <Setter Property="Margin"
                        Value="0,5"/>
        </Style>

        <Style x:Key="RoundedEntryStyle"
               TargetType="Entry"
               BasedOn="{StaticResource BaseEntryStyle}">
                <Setter Property="VisualStateManager.VisualStateGroups">
                        <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                        <Setter Property="BackgroundColor"
                                                                Value="{DynamicResource InputBackgroundColor}"/>
                                                </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Focused">
                                                <VisualState.Setters>
                                                        <Setter Property="BackgroundColor"
                                                                Value="{DynamicResource InputBackgroundColor}"/>
                                                </VisualState.Setters>
                                        </VisualState>
                                </VisualStateGroup>
                        </VisualStateGroupList>
                </Setter>
        </Style>

        <!-- Picker Styles -->
        <Style x:Key="BasePicker"
               TargetType="Picker">
                <Setter Property="BackgroundColor"
                        Value="{DynamicResource InputBackgroundColor}"/>
                <Setter Property="TextColor"
                        Value="{DynamicResource PrimaryTextColor}"/>
                <Setter Property="TitleColor"
                        Value="{DynamicResource PlaceholderTextColor}"/>
                <Setter Property="FontSize"
                        Value="14"/>
                <Setter Property="HeightRequest"
                        Value="48"/>
                <Setter Property="Margin"
                        Value="0,5"/>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button">
                <Setter Property="BackgroundColor"
                        Value="{DynamicResource ButtonBackgroundColor}"/>
                <Setter Property="TextColor"
                        Value="{DynamicResource ButtonTextColor}"/>
                <Setter Property="FontSize"
                        Value="16"/>
                <Setter Property="FontAttributes"
                        Value="Bold"/>
                <Setter Property="HeightRequest"
                        Value="48"/>
                <Setter Property="CornerRadius"
                        Value="8"/>
                <Setter Property="Margin"
                        Value="0,10"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button">
                <Setter Property="BackgroundColor"
                        Value="{DynamicResource SecondaryButtonBackgroundColor}"/>
                <Setter Property="TextColor"
                        Value="{DynamicResource SecondaryButtonTextColor}"/>
                <Setter Property="FontSize"
                        Value="14"/>
                <Setter Property="HeightRequest"
                        Value="40"/>
                <Setter Property="CornerRadius"
                        Value="6"/>
                <Setter Property="BorderColor"
                        Value="{DynamicResource BorderColor}"/>
                <Setter Property="BorderWidth"
                        Value="1"/>
                <Setter Property="Margin"
                        Value="5"/>
        </Style>

        <Style x:Key="DangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="BackgroundColor"
                        Value="{DynamicResource DangerButtonBackgroundColor}"/>
                <Setter Property="TextColor"
                        Value="White"/>
        </Style>

        <Style x:Key="IconButtonStyle"
               TargetType="Button">
                <Setter Property="BackgroundColor"
                        Value="Transparent"/>
                <Setter Property="TextColor"
                        Value="{DynamicResource PrimaryTextColor}"/>
                <Setter Property="FontSize"
                        Value="14"/>
                <Setter Property="HeightRequest"
                        Value="40"/>
                <Setter Property="WidthRequest"
                        Value="40"/>
                <Setter Property="CornerRadius"
                        Value="20"/>
                <Setter Property="Padding"
                        Value="8"/>
        </Style>

        <!-- Border Styles -->
        <Style x:Key="CardBorderStyle"
               TargetType="Border">
                <Setter Property="BackgroundColor"
                        Value="{DynamicResource CardBackgroundColor}"/>
                <Setter Property="Stroke"
                        Value="{DynamicResource BorderColor}"/>
                <Setter Property="StrokeThickness"
                        Value="1"/>
                <Setter Property="StrokeShape"
                        Value="RoundRectangle 12"/>
                <Setter Property="Margin"
                        Value="8"/>
                <Setter Property="Padding"
                        Value="16"/>
        </Style>

        <Style x:Key="ModalBorderStyle"
               TargetType="Border">
                <Setter Property="BackgroundColor"
                        Value="{DynamicResource CardBackgroundColor}"/>
                <Setter Property="Stroke"
                        Value="{DynamicResource BorderColor}"/>
                <Setter Property="StrokeThickness"
                        Value="1"/>
                <Setter Property="StrokeShape"
                        Value="RoundRectangle 16,16,0,0"/>
                <Setter Property="Padding"
                        Value="24"/>
                <Setter Property="Margin"
                        Value="0"/>
        </Style>

        <!-- Status Badge Styles -->
        <Style x:Key="StatusBadgeStyle"
               TargetType="Border">
                <Setter Property="StrokeShape"
                        Value="RoundRectangle 12"/>
                <Setter Property="Padding"
                        Value="8,4"/>
                <Setter Property="Margin"
                        Value="4,0"/>
                <Setter Property="HeightRequest"
                        Value="24"/>
                <Setter Property="VerticalOptions"
                        Value="Center"/>
        </Style>

        <!-- CollectionView Styles -->
        <Style x:Key="BaseCollectionViewStyle"
               TargetType="CollectionView">
                <Setter Property="BackgroundColor"
                        Value="Transparent"/>
                <Setter Property="SelectionMode"
                        Value="None"/>
        </Style>

        <!-- Grid Styles -->
        <Style x:Key="FormGridStyle"
               TargetType="Grid">
                <Setter Property="Margin"
                        Value="20"/>
                <Setter Property="RowSpacing"
                        Value="16"/>
        </Style>

        <!-- ActivityIndicator Styles -->
        <Style x:Key="LoadingIndicatorStyle"
               TargetType="ActivityIndicator">
                <Setter Property="Color"
                        Value="{DynamicResource PrimaryColor}"/>
                <Setter Property="HeightRequest"
                        Value="40"/>
                <Setter Property="WidthRequest"
                        Value="40"/>
        </Style>

        <!-- Shadow Styles -->
        <Style x:Key="CardShadowStyle"
               TargetType="Shadow">
                <Setter Property="Brush"
                        Value="Black"/>
                <Setter Property="Offset"
                        Value="0,2"/>
                <Setter Property="Radius"
                        Value="4"/>
                <Setter Property="Opacity"
                        Value="0.1"/>
        </Style>

        <!-- Additional Entry Style with Border -->
        <Style x:Key="BorderedEntryStyle"
                        TargetType="Entry"
                        BasedOn="{StaticResource BaseEntryStyle}">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource InputBackgroundColor}"/>
                <Setter Property="VisualStateManager.VisualStateGroups">
                        <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="Focused">
                                                <VisualState.Setters>
                                                        <Setter Property="BackgroundColor"
                                                                        Value="{DynamicResource InputBackgroundColor}"/>
                                                </VisualState.Setters>
                                        </VisualState>
                                </VisualStateGroup>
                        </VisualStateGroupList>
                </Setter>
        </Style>

        <!-- Improved Stepper Style -->
        <Style x:Key="BaseStepperStyle"
                        TargetType="Stepper">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource InputBackgroundColor}"/>
                <Setter Property="Margin"
                                Value="0,5"/>
        </Style>

        <!-- WebView Style -->
        <Style x:Key="BaseWebViewStyle"
                        TargetType="WebView">
                <Setter Property="BackgroundColor"
                                Value="{DynamicResource PageBackgroundColor}"/>
        </Style>

        <!-- Ellipse Styles for Status Indicators -->
        <Style x:Key="StatusIndicatorStyle"
                        TargetType="Ellipse">
                <Setter Property="WidthRequest"
                                Value="12"/>
                <Setter Property="HeightRequest"
                                Value="12"/>
                <Setter Property="VerticalOptions"
                                Value="Center"/>
                <Setter Property="HorizontalOptions"
                                Value="Center"/>
        </Style>

        <!-- BoxView Styles -->
        <Style x:Key="OverlayBoxViewStyle"
                        TargetType="BoxView">
                <Setter Property="Color"
                                Value="{DynamicResource OverlayBackgroundColor}"/>
                <Setter Property="Opacity"
                                Value="0.5"/>
        </Style>

</ResourceDictionary>